DJANGO_SECRET_KEY=replace-with-strong-secret
DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,web,webhook_web,host.docker.internal
TIME_ZONE=UTC

POSTGRES_DB=webhooks
POSTGRES_USER=webhooks
POSTGRES_PASSWORD=webhooks
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DB_CONN_MAX_AGE=60

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_TIME_LIMIT=120
CELERY_TASK_SOFT_TIME_LIMIT=90

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
NORMALIZATION_PROMPT_VERSION=v1
LOW_CONFIDENCE_THRESHOLD=0.70

DJANGO_LOG_LEVEL=INFO
DRF_ANON_THROTTLE=1200/min
